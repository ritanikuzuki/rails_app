<!-- ログインページ -->
<div class="login-container">
  <div class="login-card animate-slideUp">
    <div class="login-logo">⚡</div>
    <h1 class="login-title">TaskPenalty</h1>
    <p class="login-subtitle">期限を守るモチベーション管理ツール</p>

    <% if flash[:alert] %>
      <div class="flash flash-alert mb-2" style="margin: 0 0 1.5rem; font-size: 0.85rem;">
        <span><%= flash[:alert] %></span>
      </div>
    <% end %>
    <% if flash[:notice] %>
      <div class="flash flash-notice mb-2" style="margin: 0 0 1.5rem; font-size: 0.85rem;">
        <span><%= flash[:notice] %></span>
      </div>
    <% end %>

    <!-- Google ログインボタン -->
    <%= button_to user_google_oauth2_omniauth_authorize_path,
        data: { turbo: false },
        class: "btn btn-google btn-lg btn-block" do %>
      <svg width="20" height="20" viewBox="0 0 48 48">
        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
      </svg>
      Googleアカウントでログイン
    <% end %>

    <!-- 区切り線 -->
    <div style="display: flex; align-items: center; gap: 1rem; margin: 1.5rem 0; color: var(--text-muted);">
      <hr style="flex: 1; border: none; border-top: 1px solid var(--border-color);">
      <span style="font-size: 0.8rem;">または</span>
      <hr style="flex: 1; border: none; border-top: 1px solid var(--border-color);">
    </div>

    <!-- メールでログイン（開発用） -->
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-group">
        <%= f.email_field :email, class: "form-input", placeholder: "メールアドレス", autofocus: true, autocomplete: "email" %>
      </div>
      <div class="form-group">
        <%= f.password_field :password, class: "form-input", placeholder: "パスワード", autocomplete: "current-password" %>
      </div>
      <%= f.submit "メールでログイン", class: "btn btn-secondary btn-lg btn-block" %>
    <% end %>

    <div class="login-features">
      <div class="login-feature">
        <span class="login-feature-icon">📋</span>
        <span>4つのモードでタスクを管理</span>
      </div>
      <div class="login-feature">
        <span class="login-feature-icon">💰</span>
        <span>期限を逃したら自動課金でモチベーションUP</span>
      </div>
      <div class="login-feature">
        <span class="login-feature-icon">🎯</span>
        <span>マイルストーンで大きなタスクを分割</span>
      </div>
      <div class="login-feature">
        <span class="login-feature-icon">❤️</span>
        <span>課金された金額は募金先へ寄付</span>
      </div>
    </div>
  </div>
</div>
