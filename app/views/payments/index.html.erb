<!-- 課金履歴＆カード管理ページ -->
<div class="task-detail animate-fadeIn">
  <div class="flex-between mb-2">
    <div>
      <h1 class="page-title">💳 支払い設定と履歴</h1>
      <p class="page-subtitle">カードの管理と、これまでの課金履歴を確認できます</p>
    </div>
    <a href="<%= new_payment_path %>" class="btn btn-primary btn-sm">+ カードを追加</a>
  </div>

  <!-- カード管理セクション -->
  <div class="section-title mb-1">登録済みのカード</div>
  <div class="card mb-3">
    <% if @payment_methods.any? %>
      <div class="card-list">
        <% @payment_methods.each do |pm| %>
          <div class="card-item" style="display: flex; justify-content: space-between; align-items: center; padding: 1rem; border-bottom: 1px solid var(--border-color);">
            <div style="display: flex; align-items: center; gap: 1rem;">
              <div class="card-icon" style="font-size: 1.5rem;">
                <%= case pm.card.brand
                    when "visa" then "💳"
                    when "mastercard" then "💳"
                    when "jcb" then "💳"
                    else "💳"
                    end %>
              </div>
              <div>
                <div style="font-weight: 600; text-transform: capitalize;">
                  <%= pm.card.brand %> **** <%= pm.card.last4 %>
                  <% if pm.id == @default_payment_method_id %>
                    <span class="badge badge-success" style="margin-left: 0.5rem;">メイン</span>
                  <% end %>
                </div>
                <div class="text-muted" style="font-size: 0.75rem;">
                  有効期限: <%= pm.card.exp_month %>/<%= pm.card.exp_year %>
                </div>
              </div>
            </div>
            
            <div style="display: flex; gap: 0.5rem;">
              <% if pm.id != @default_payment_method_id %>
                <%= button_to "メインに設定", make_default_payment_path(pm.id), method: :patch, class: "btn btn-secondary btn-sm" %>
              <% end %>
              <%= button_to "削除", destroy_card_payment_path(pm.id), method: :delete, data: { confirm: "このカードを削除しますか？" }, class: "btn btn-outline-danger btn-sm" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div style="padding: 2rem; text-align: center;" class="text-muted">
        登録されているカードはありません
      </div>
    <% end %>
  </div>

  <div class="section-title mb-1">課金・寄付履歴</div>
  <!-- 統計 -->
  <div class="stats-grid mb-2">
    <div class="stat-card">
      <div class="stat-value" style="background: var(--gradient-danger); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        ¥<%= number_with_delimiter(@charges.where(status: :succeeded).sum(:amount)) %>
      </div>
      <div class="stat-label">課金総額</div>
    </div>
    <div class="stat-card">
      <div class="stat-value"><%= @charges.where(status: :succeeded).count %></div>
      <div class="stat-label">課金回数</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="background: var(--gradient-success); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        ¥<%= number_with_delimiter(@charges.where(status: :succeeded).sum(:amount)) %>
      </div>
      <div class="stat-label">寄付総額 ❤️</div>
    </div>
  </div>

  <% if @charges.any? %>
    <div class="card">
      <div class="charge-list">
        <% @charges.each do |charge| %>
          <div class="charge-item">
            <div style="display: flex; align-items: center; gap: 1rem;">
              <div>
                <div class="charge-amount <%= charge.status %>">
                  ¥<%= number_with_delimiter(charge.amount) %>
                </div>
                <div class="text-muted" style="font-size: 0.78rem;">
                  <%= charge.created_at.strftime("%Y/%m/%d %H:%M") %>
                </div>
              </div>
            </div>
            <div style="display: flex; align-items: center; gap: 1rem;">
              <% if charge.task %>
                <a href="<%= task_path(charge.task) %>" class="text-muted" style="font-size: 0.85rem;">
                  📋 <%= charge.task.title.truncate(20) %>
                </a>
              <% end %>
              <span class="badge badge-<%= charge.succeeded? ? 'danger' : (charge.charge_pending? ? 'warning' : 'info') %>">
                <% if charge.succeeded? %>
                  課金完了
                <% elsif charge.charge_pending? %>
                  処理中
                <% else %>
                  失敗
                <% end %>
              </span>
              <% if charge.donation_destination %>
                <span class="badge badge-success">❤️ <%= charge.donation_destination %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="empty-state">
       <div class="empty-state-icon">📄</div>
      <div class="empty-state-text">課金履歴はまだありません</div>
    </div>
  <% end %>
</div>
